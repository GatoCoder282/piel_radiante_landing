# Copia este archivo a .env.local y completa con valores reales.

# Número de WhatsApp de Piel Radiante en formato internacional SIN '+' ni espacios.
# Ej: 59170000000  (Bolivia +591 + número)
NEXT_PUBLIC_WHATSAPP_NUMBER=59170000000

# Google Analytics 4 — Measurement ID (G-XXXXXXXXXX). Dejar vacío desactiva GA.
NEXT_PUBLIC_GA_ID=

# Meta (Facebook) Pixel ID. Dejar vacío desactiva el Pixel.
NEXT_PUBLIC_META_PIXEL_ID=
